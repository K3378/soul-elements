PORT=3001
NODE_ENV=production

# Stripe
# Set STRIPE_SECRET_KEY in Railway dashboard (Stripe Dashboard > Developers > API Keys)
STRIPE_SECRET_KEY=

# Stripe Webhook Secret (set this in Railway dashboard after configuring webhook endpoint)
# Get it from Stripe Dashboard > Developers > Webhooks > Add endpoint
# Endpoint URL: https://stemssouls.up.railway.app/webhook/stripe
STRIPE_WEBHOOK_SECRET=

# Frontend URL (for CORS and redirects)
FRONTEND_URL=https://stemssouls.up.railway.app
